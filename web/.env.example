NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Forgot password: in Supabase Dashboard > Auth > URL Configuration, add Redirect URL: https://your-domain.com/login/reset-password
NEXT_PUBLIC_MAPBOX_TOKEN=

# Admin backend (optional; server-side only)
# SUPABASE_SERVICE_ROLE_KEY=
# INGEST_HEALTH_URL=http://localhost:8090
# ADMIN_RETENTION_DAYS=90

# Stock: Simbase SIM cards (admin Stock page)
# SIMBASE_API_KEY=your_bearer_token
# SIMBASE_API_URL=https://api.simbase.com/v2

# Australia Post tracking (customer order detail – optional)
# AUSPOST_API_KEY=your_secure_api_key

# SMS alerts (SMSPortal – GPS tracking alerts, 30/month per user)
# https://docs.smsportal.com/docs/api-keys
# SMSPORTAL_CLIENT_ID=your_client_id
# SMSPORTAL_API_SECRET=your_api_secret
# SMSPORTAL_SENDER_ID=RooGPS
# SMSPORTAL_API_URL=https://rest.smsportal.com

# Stripe (payments and SIM subscriptions)
# Dashboard: https://dashboard.stripe.com/apikeys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret (Stripe CLI or Dashboard > Developers > Webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring price IDs for SIM plans (create Products/Prices in Stripe for monthly and yearly)
# STRIPE_PRICE_SIM_MONTHLY=price_...
# STRIPE_PRICE_SIM_YEARLY=price_...
