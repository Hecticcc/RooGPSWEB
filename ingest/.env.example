SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
INGEST_HOST=0.0.0.0
INGEST_PORT=8011
REQUIRE_DEVICE_PREEXIST=true
LOG_LEVEL=info
HEALTH_PORT=8090
MAX_SOCKET_BUFFER_BYTES=1048576
LOG_MAX_PER_SEC=20
SUPABASE_RETRIES=3
# Device lookup cache: new devices are seen within negative TTL without restart (default 60s cache, 30s for "not found")
# DEVICE_CACHE_TTL_MS=60000
# When device not found, retry once after this delay before deadlettering (handles "just added" / replication lag)
# DEVICE_CHECK_RETRY_DELAY_MS=3000
# Optional: device local timezone for gpsTimeLocal (default Australia/Melbourne)
DEVICE_TIMEZONE=Australia/Melbourne
# Optional: name of this ingest server (e.g. Skippy, Joey). Stored on each location row; shown in dashboard Settings as "Server".
# INGEST_SERVER_NAME=Skippy

# --- JT808 parallel ingest (node dist/jt808-server.js) — GAT24 / standard JT808 TCP ---
# INGEST_JT808_PORT=8012
# HEALTH_JT808_PORT=8091
# INGEST_JT808_SERVER_NAME=GAT24-test
# JT808_AUTH_CODE=123456

# Simbase API — used by the carrier poller to detect SIM carrier changes.
# Required for the network-history bar to show real carrier switches.
SIMBASE_API_URL=https://api.simbase.com/v2
SIMBASE_API_KEY=
# How often (ms) to poll Simbase for carrier changes. Default: 30 minutes.
# CARRIER_POLL_INTERVAL_MS=1800000
